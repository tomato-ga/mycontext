{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types", "node"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "../mycontext-sync/src/authorStyle.ts", "../mycontext-sync/src/authorStyleRouting.ts", "../mycontext-sync/src/hash.ts", "../mycontext-sync/src/types.ts"]
}
