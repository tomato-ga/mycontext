NOTION_API_KEY=<notion-integration-secret>
NOTION_VERSION=2026-03-11

TIDB_HOST=<tidb-host>
TIDB_PORT=4000
TIDB_USER=<tidb-sync-writer-user>
TIDB_PASSWORD=<tidb-password>
TIDB_DATABASE=notion_context
TIDB_ENABLE_SSL=true
TIDB_CA_PATH=

# Optional: keep personal Notion page IDs/titles in .env instead of
# mirror.config.json. This value takes precedence when present.
MIRROR_CONFIG_JSON={"pages":[{"pageId":"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx","title":"Example Context Page"}]}

# Absolute path to the local noteAI repository. The editor knowledge commands
# use a fixed allowlist of 8 Markdown paths below this root.
EDITOR_KNOWLEDGE_SOURCE_ROOT=<absolute-path-to-noteAI>

# Absolute path whose children include startup-science/ and marketing-wisdom/.
# Only the two fixed Markdown paths allowlisted in code are read.
BUSINESS_KNOWLEDGE_SOURCE_ROOT=<absolute-path-to-.claude-skills>

# Absolute path to noteAI. Only the two fixed author-style Markdown paths in
# knowledge/ are read by the dedicated author-style commands.
AUTHOR_STYLE_SOURCE_ROOT=<absolute-path-to-noteAI>

# Absolute path to the kindle repository. The dedicated metaskill commands read
# only docs/メタスキル_文字起こし.md below this root.
METASKILL_SOURCE_ROOT=<absolute-path-to-kindle>
